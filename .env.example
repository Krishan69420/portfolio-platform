# ============================================================
# Portfolio Platform - Root Environment Variables
# Copy to .env and fill in the values
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_strong_db_password

# ── JWT (REQUIRED - generate with: openssl rand -hex 64) ──
JWT_SECRET=replace_with_at_least_64_random_characters_for_production_use

# ── JWT Expiry ────────────────────────────────────────────
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# ── Environment ───────────────────────────────────────────
ENVIRONMENT=production

# ── CORS Origins (comma-separated) ───────────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Uploads ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Logging ───────────────────────────────────────────────
RUST_LOG=portfolio_backend=info,tower_http=info,sqlx=warn
